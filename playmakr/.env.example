# Anthropic (agent brain)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-5-haiku-latest

# Brevo (SMS)
BREVO_API_KEY=
BREVO_SENDER_NUMBER=

# Proactive scheduler
SCHEDULER_INTERVAL_MIN=5

# Highlights via X/Twitter (optional; falls back to search links if unset)
TWITTER_BEARER_TOKEN=
# Optional comma-separated X handles to source clips from. Empty = search all of X.
HIGHLIGHT_ACCOUNTS=
